# =============================================================================
# .env.prod.example — template para deploy em producao
# =============================================================================
# Copie para .env.prod, preencha os valores reais e use:
#   docker compose --env-file .env.prod up -d --build
#
# Em CI/CD, configure essas variaveis no painel de secrets (GitHub Actions,
# AWS Secrets Manager, Vault, etc.) ao inves de manter um arquivo em disco.
# =============================================================================

# ----- Postgres (use credenciais especificas, nao 'postgres'/'postgres') -----
POSTGRES_DB=liber
POSTGRES_USER=liber_app
POSTGRES_PASSWORD=<GERAR-COM-openssl-rand-base64-24>
POSTGRES_PORT=5432

# ----- Admin -----
# Opcao 1: setar a senha aqui (forte!)
# Opcao 2: deixar vazio para o seeder gerar e logar UMA vez no startup
ADMIN_EMAIL=admin@suaescola.edu.br
ADMIN_NOME=Administrador
ADMIN_PASSWORD=<GERAR-FORTE-OU-DEIXAR-VAZIO-PARA-GERACAO-AUTOMATICA>

# ----- JWT (OBRIGATORIO: gerar com openssl rand -base64 48) -----
JWT_SECRET=<GERAR-COM-openssl-rand-base64-48>
JWT_ISSUER=liber
# Access token 15min, refresh token 7 dias (ajuste conforme politica)
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ----- CORS (lista exata de origens, SEM localhost em producao) -----
CORS_ALLOWED_ORIGINS=https://liber-escola.duckdns.org

# ----- Dominio publico + TLS (Caddy + Let's Encrypt) -----
# DuckDNS gratuito: crie em https://www.duckdns.org/ e atualize o IP da VM
DOMAIN=liber-escola.duckdns.org
ACME_EMAIL=seu-email@gmail.com

# ----- Imagens Docker (GHCR — preenchido pelo CI no deploy) -----
# Em deploy manual local, pode deixar comentado pra usar build local
# APP_IMAGE=ghcr.io/SEU-USUARIO-GITHUB/liber-app:latest
# FRONTEND_IMAGE=ghcr.io/SEU-USUARIO-GITHUB/liber-frontend:latest

# ----- Profile Spring -----
# 'prod' ativa application-prod.properties: logs JSON, sem SQL, erros nao detalhados
SPRING_PROFILES_ACTIVE=prod

# ----- Toggles de producao -----
# Registro publico DESLIGADO — novos usuarios so via POST /api/v1/usuarios (ADMIN)
AUTH_PUBLIC_REGISTER_ENABLED=false
# Rate limit no login obrigatorio em prod
RATE_LIMIT_LOGIN_ENABLED=true

# ----- Server -----
SERVER_PORT=8080

# ----- Spring profile (opcional) -----
# SPRING_PROFILES_ACTIVE=prod
