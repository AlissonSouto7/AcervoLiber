# =============================================================================
# .env.example — template para overrides locais/producao
# =============================================================================
# Copie para .env (que esta no .gitignore) e ajuste os valores.
# O docker-compose.yml le este arquivo automaticamente.
#
# Para producao, REGENERAR JWT_SECRET com:
#   openssl rand -base64 48
# =============================================================================

# Admin seedado no primeiro boot
ADMIN_EMAIL=admin@liber.local
ADMIN_NOME=Administrador
ADMIN_PASSWORD=@Admin2026

# JWT — access token 15min, refresh token 7 dias
JWT_SECRET=dev-jwt-secret-liber-trocar-em-prod-32-bytes-OK-A1B2C3D4E5F6
JWT_ISSUER=liber
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS — separar dominios por virgula
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Toggles
AUTH_PUBLIC_REGISTER_ENABLED=true
RATE_LIMIT_LOGIN_ENABLED=true

# Capas de livro — chave da Google Books API (OPCIONAL).
# Sem chave: so a Open Library e consultada (cobertura menor de livros nacionais).
# Com chave: a Google Books entra primeiro (cobertura bem maior).
# Gere de graca em https://console.cloud.google.com/apis/credentials
#GOOGLE_BOOKS_API_KEY=
