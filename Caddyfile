# =============================================================================
# Caddyfile — reverse proxy com TLS automatico (Let's Encrypt)
# =============================================================================
# Caddy escuta em 80/443 no host, obtem certificado Let's Encrypt sozinho via
# HTTP-01 challenge, e faz proxy reverso para o container frontend (que ja
# tem nginx com proxy_pass /api -> app:8080 internamente).
#
# Variavel obrigatoria no .env.prod do servidor:
#   DOMAIN=liber-escola.duckdns.org   (ou o subdominio DuckDNS que voce criar)
#   ACME_EMAIL=seu-email@gmail.com    (para avisos do Let's Encrypt)
# =============================================================================

{
	# Email para o Let's Encrypt notificar sobre renovacao/problemas
	email {$ACME_EMAIL}

	# Em caso de problema com Let's Encrypt, descomente para testar com staging
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
	# Proxy reverso para o container frontend (nginx interno escuta em 8080)
	reverse_proxy frontend:8080

	# Compressao
	encode gzip zstd

	# Headers de seguranca — defesa em profundidade alem do que o backend ja envia.
	# Cobre os deferidos das Fases 4.D / 6.B do AUDIT_DEEP_SECURITY:
	#   Permissions-Policy, Cross-Origin-Opener-Policy, Cross-Origin-Resource-Policy
	header {
		# HSTS — 1 ano, inclui subdominios (Caddy ja envia, mas tornamos explicito)
		Strict-Transport-Security "max-age=31536000; includeSubDomains"

		# Bloqueia APIs sensiveis que o app nao usa
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

		# Isolamento de janela/recursos (defesa contra Spectre/XSLeak)
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-site"

		# Esconde versao do servidor (reconnaissance)
		-Server
		-X-Powered-By
	}

	# index.html sem cache — garante que deploy de fix propaga imediatamente.
	# Assets com hash no nome (bundle.[hash].js) podem cachear forever.
	@indexHtml path /index.html /
	header @indexHtml Cache-Control "no-cache, no-store, must-revalidate"

	# Log de acesso (rotaciona automaticamente)
	log {
		output file /var/log/caddy/access.log {
			roll_size 10mb
			roll_keep 5
			roll_keep_for 720h
		}
		format json
	}
}
